# ==============================================================================
# TransitOps - Git Ignore Rules
# ==============================================================================

# Dependencies
node_modules/
/.pnp
.pnp.js

# Testing & Coverage
coverage/
*.lcov
.nyc_output/

# Production & Build Outputs
dist/
dist-ssr
build/
*.tsbuildinfo
.next/
out/

# Environment Variables & Secrets (CRITICAL SECURITY RULE: NEVER COMMIT SECRETS OR .ENV)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.pem
*.key
credentials.json
secrets/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime Data
pids
*.pid
*.seed
*.pid.lock
*.local

# IDE & Editor Configuration
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary & Cache Directories
.cache/
tmp/
temp/
*.tmp
