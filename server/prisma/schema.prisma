datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  DISPATCHER
  FLEET_MANAGER
  SAFETY_OFFICER
  FINANCE
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

/// Represents a system user
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

/// Represents a fleet vehicle
model Vehicle {
  id                 Int           @id @default(autoincrement())
  registrationNumber String        @unique
  model              String
  type               String
  capacity           Int
  odometer           Int
  acquisitionCost    Decimal       @db.Decimal(10, 2)
  status             VehicleStatus
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips        Trip[]
  maintenances Maintenance[]
  fuelLogs     FuelLog[]
  expenses     Expense[]

  @@index([status])
  // Composite: status filter + createdAt DESC ordering used by getVehicles()
  @@index([status, createdAt])
}

/// Represents a driver
model Driver {
  id            Int          @id @default(autoincrement())
  name          String
  licenseNumber String       @unique
  category      String
  expiryDate    DateTime
  contact       String
  safetyScore   Decimal      @db.Decimal(5, 2)
  status        DriverStatus
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  trips Trip[]

  @@index([status])
}

/// Represents a trip assignment
model Trip {
  id              Int        @id @default(autoincrement())
  vehicleId       Int
  driverId        Int
  source          String
  destination     String
  cargoWeight     Decimal    @db.Decimal(10, 2)
  plannedDistance Decimal    @db.Decimal(10, 2)
  actualDistance  Decimal?   @db.Decimal(10, 2)
  fuelUsed        Decimal?   @db.Decimal(10, 2)
  status          TripStatus
  startTime       DateTime
  endTime         DateTime?
  createdAt       DateTime   @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([startTime, endTime])
  // Composite: all trips for a vehicle filtered by status (e.g. active trips per vehicle)
  @@index([vehicleId, status])
  // Composite: all trips for a driver filtered by status
  @@index([driverId, status])
}

/// Represents a vehicle maintenance record
model Maintenance {
  id          Int               @id @default(autoincrement())
  vehicleId   Int
  serviceType String
  description String
  cost        Decimal           @db.Decimal(10, 2)
  status      MaintenanceStatus
  startDate   DateTime
  endDate     DateTime?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([vehicleId])
  @@index([status])
  @@index([startDate, endDate])
  // Composite: open/in-progress maintenance scoped to a vehicle (IN_SHOP dashboard check)
  @@index([vehicleId, status])
}

/// Represents a fuel consumption log
model FuelLog {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  liters    Decimal  @db.Decimal(10, 2)
  cost      Decimal  @db.Decimal(10, 2)
  date      DateTime

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([vehicleId])
  @@index([date])
}

/// Represents an operational expense
model Expense {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  category    String
  amount      Decimal  @db.Decimal(10, 2)
  description String
  date        DateTime

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([vehicleId])
  @@index([date, category])
}
